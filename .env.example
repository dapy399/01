# ==========================================
# AI医疗RAG项目 - 环境变量配置示例
# 复制此文件为 .env 并填写真实值
# ==========================================

# JWT密钥（用于用户认证）
JWT_SECRET=your-jwt-secret-key

# 密码加密密钥
PASSWORD_KEY=your-password-key

# 通义千问API密钥
TONGYI_AKI_KEY=sk-your-tongyi-api-key

# Milvus向量数据库配置
MILVUS_ADDRESS=https://your-milvus-address.cloud.zilliz.com
MILVUS_TOKEN=your-milvus-token

# Tavily搜索API密钥（联网搜索用）
TAVILY_API_KEY=tvly-your-tavily-api-key

# 必应搜索API密钥（可选）
BING_SEARCH_API_KEY=your-bing-api-key

# 图片服务域名
IMAGE_BASE_URL_local=http://121.43.149.193:7005/open-image
